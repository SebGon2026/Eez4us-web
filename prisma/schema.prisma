generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// better-auth core
// ============================================

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  emailVerified Boolean  @default(false)
  name          String?
  image         String?

  // Eez4us custom fields
  schoolId  String?
  role      String  @default("parent") // parent | director | support_staff | logistics | vendor | super_admin
  phoneE164 String?
  // false = acceso revocado. Soft-disable: el director da de baja personal sin
  // borrar la cuenta (preserva la atribución de entregas / prueba de entrega).
  active    Boolean @default(true)
  // 2FA por email (plugin twoFactor de better-auth, TOTP deshabilitado). Obligatorio
  // para director/super_admin — se fuerza al crear el usuario, no es opt-in.
  twoFactorEnabled Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions Session[]
  accounts Account[]
  school   School?   @relation(fields: [schoolId], references: [id])

  // parent-specific
  authorizedFamilies AuthorizedFamily[]
  vehicles           Vehicle[]
  parentStudents     ParentStudent[]
  trips              Trip[]             @relation("TripParent")

  // staff
  finalizedTrips        Trip[]        @relation("TripFinalizedBy")
  finalizedTripStudents TripStudent[] @relation("TripStudentFinalizedBy")

  // invitations claimed
  claimedInvitation Invitation? @relation("InvitationClaimedBy")

  // vendor
  vendor Vendor?

  // tickets
  ticketsReported SupportTicket[]

  // push + alerts
  pushTokens   PushToken[]
  alertsTarget Alert[]     @relation("AlertTargetUser")

  // messaging
  conversationsAsParent Conversation[] @relation("ConvParent")
  messagesSent          Message[]      @relation("MessageSender")

  // temporary authorizations
  tempAuthsCreated TemporaryAuthorization[] @relation("TempAuthParent")
  tempAuthsUsed    TemporaryAuthorization[] @relation("TempAuthUsedBy")

  // audit & imports
  auditLogs       AuditLog[]    @relation("AuditActor")
  importJobs      ImportJob[]   @relation("ImportJobCreator")

  // notifications
  notifications Notification[] @relation("UserNotifications")

  // 2FA (better-auth twoFactor)
  twoFactors TwoFactor[]

  @@index([schoolId])
  @@map("users")
}

// Tabla del plugin twoFactor de better-auth. Con TOTP deshabilitado solo se usa si
// algún día se habilita TOTP/backup codes; el flujo OTP-por-email vive en Verification.
model TwoFactor {
  id          String  @id @default(cuid())
  secret      String
  backupCodes String
  userId      String
  verified    Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("two_factors")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id           String    @id @default(cuid())
  userId       String
  accountId    String
  providerId   String
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  password     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

model Jwks {
  id         String   @id @default(cuid())
  publicKey  String
  privateKey String
  createdAt  DateTime @default(now())

  @@map("jwks")
}

// ============================================
// Schools + pickup points + grades + students
// ============================================

model School {
  id           String  @id @default(cuid())
  name         String
  internalCode String  @unique // código corto único para asociar padres
  addressText  String?
  addressLat   Float?
  addressLng   Float?
  city         String?
  country      String? // ISO o nombre legible; alimenta presencia global del super-admin

  // branding del colegio (login + admin)
  logoUrl           String?
  brandHue          Int?    // tonalidad HSL (0-360) para color primario en su login
  brandHueSecondary Int?    // tonalidad HSL (0-360) para color de acento (íconos, bandas)

  // localización del panel admin: "es-MX" (default) | "es-AR" (voseo)
  locale        String  @default("es-MX")
  // densidad de la UI del panel admin: "comfortable" (default) | "compact" | "spacious"
  density       String  @default("comfortable")
  // zona horaria IANA del colegio (ej. "America/El_Salvador", "America/Argentina/Buenos_Aires").
  // Sin esto los reportes y dismissalTime se interpretan en UTC y dan días corridos. Default
  // alineado al locale es-MX. El wizard/ajustes lo setean por país.
  timezone      String  @default("America/Mexico_City")
  // moneda de cobro de ESTA escuela (ISO 4217). El modelo B2B2C cobra por país, no siempre USD.
  currency      String  @default("USD")

  stripeCustomerId String? @unique
  // Cliente Openpay (México). Paralelo a stripeCustomerId; el ruteo por país/moneda decide cuál se cobra.
  openpayCustomerId String? @unique

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users             User[]
  pickupPoints      PickupPoint[]
  grades            Grade[]
  students          Student[]
  invitations       Invitation[]
  trips             Trip[]
  subscription      Subscription?
  tickets           SupportTicket[]
  enrolledByVendors VendorSchool[]
  alerts            Alert[]

  conversations           Conversation[]
  temporaryAuthorizations TemporaryAuthorization[]
  importJobs              ImportJob[]
  commissions             Commission[]             @relation("SchoolCommissions")
  invoices                Invoice[]                @relation("SchoolInvoices")

  @@map("schools")
}

model PickupPoint {
  id           String   @id @default(cuid())
  schoolId     String
  name         String   // "Puerta principal", "Puerta lateral"
  centerLat    Float
  centerLng    Float
  radiusMeters Int      @default(150)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  trips  Trip[]

  @@index([schoolId])
  @@map("pickup_points")
}

model Grade {
  id            String   @id @default(cuid())
  schoolId      String
  name          String   // "Primero A"
  level         String?  // INICIAL | PRIMARIA | SECUNDARIA
  dismissalTime String?  // "12:30" — hora local de salida
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())

  school   School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  students Student[]

  @@unique([schoolId, name])
  @@index([schoolId, dismissalTime])
  @@map("grades")
}

enum PickupMode {
  PRIVATE_VEHICLE // recogido por un representante en su vehículo particular
  TRANSPORT // transporte escolar/privado (van o bus)
  WALKING // el representante lo recoge a pie (usa "estoy afuera", sin vehículo ni GPS)
}

enum TransportVehicleType {
  BUS
  VAN
}

model Student {
  id         String    @id @default(cuid())
  schoolId   String
  gradeId    String?
  firstName  String
  lastName   String
  birthDate  DateTime?
  externalId String? // matrícula interna de la escuela
  active     Boolean   @default(true)

  // Modo de recogida
  pickupMode           PickupMode            @default(PRIVATE_VEHICLE)
  transportName        String? // responsable del transporte (van/bus)
  transportPlate       String? // placa del vehículo de transporte
  transportPhone       String?
  transportVehicleType TransportVehicleType?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  school       School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  grade        Grade?          @relation(fields: [gradeId], references: [id])
  parents      ParentStudent[]
  tripStudents TripStudent[]

  @@unique([schoolId, externalId])
  @@index([schoolId])
  @@index([gradeId])
  @@map("students")
}

model ParentStudent {
  id        String   @id @default(cuid())
  parentId  String
  studentId String
  createdAt DateTime @default(now())

  parent  User    @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
  @@index([parentId])
  @@index([studentId])
  @@map("parent_students")
}

// ============================================
// Parent assets
// ============================================

model Vehicle {
  id        String   @id @default(cuid())
  parentId  String
  plate     String
  model     String
  color     String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  parent User   @relation(fields: [parentId], references: [id], onDelete: Cascade)
  trips  Trip[]

  @@index([parentId])
  @@map("vehicles")
}

model AuthorizedFamily {
  id           String   @id @default(cuid())
  parentId     String
  fullName     String
  relationship String? // "Tío", "Abuela"
  // tipo de documento del país: DUI (SV) | DNI (AR) | RFC, CURP (MX) | PASSPORT | OTHER.
  // Texto libre (no enum) para sumar países sin migración. null = legado sin tipo.
  documentType String?
  idNumber     String?
  idPhotoUrl   String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  parent User   @relation(fields: [parentId], references: [id], onDelete: Cascade)
  trips  Trip[]

  @@index([parentId])
  @@map("authorized_families")
}

// ============================================
// Invitations (Excel-driven parent onboarding)
// ============================================

enum InvitationChannel {
  EMAIL
  WHATSAPP
}

enum InvitationStatus {
  PENDING
  SENT
  CLAIMED
  EXPIRED
  REVOKED
}

model Invitation {
  id              String            @id @default(cuid())
  schoolId        String
  token           String            @unique
  channel         InvitationChannel
  contactValue    String // email address O phone E.164
  recipientName   String?
  studentIds      String[] // los students que se atan al claim
  status          InvitationStatus  @default(PENDING)
  expiresAt       DateTime
  sentAt          DateTime?
  claimedAt       DateTime?
  claimedByUserId String?           @unique
  createdAt       DateTime          @default(now())

  school    School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  claimedBy User?  @relation("InvitationClaimedBy", fields: [claimedByUserId], references: [id])

  @@index([schoolId])
  @@index([contactValue])
  @@index([status])
  @@map("invitations")
}

// ============================================
// Trips (the "voy en camino" flow)
// ============================================

enum TripStatus {
  EN_CAMINO
  EN_ZONA
  ENTREGADO
  CANCELADO
}

// Cómo arrancó la recogida:
// EN_CAMINO    = padre con "voy en camino" (GPS + ETA)
// ESTOY_AFUERA = padre ya en la puerta, sin GPS (botón "Estoy afuera")
// WALKUP       = viaje sintético creado por la miss al escanear sin recogida activa
enum TripOrigin {
  EN_CAMINO
  ESTOY_AFUERA
  WALKUP
}

enum TripEventType {
  STARTED
  POSITION_UPDATE
  ARRIVED_GEOFENCE
  // Llegada confirmada por el padre con el botón "Llegué"/"Estoy afuera", NO por geofence.
  // Distinta de ARRIVED_GEOFENCE para que el reporte/auditoría separe ambos avisos.
  ARRIVED_MANUAL
  DELIVERED_MANUAL
  CANCELLED
}

model Trip {
  id                 String  @id @default(cuid())
  schoolId           String
  pickupPointId      String
  parentId           String
  // null = walk-up: alguien llega a la puerta con la tarjeta del alumno sin que el padre
  // haya arrancado un viaje (sin vehículo ni GPS). Ver isWalkup.
  vehicleId          String?
  authorizedFamilyId String?

  // Viaje sintético creado por la miss al escanear una tarjeta sin recogida en curso
  // (§A7-ter, walk-up puro). Se excluye de los flujos del padre; vive solo para el portón.
  isWalkup Boolean @default(false)

  origin TripOrigin @default(EN_CAMINO)

  status            TripStatus @default(EN_CAMINO)
  startedAt         DateTime   @default(now())
  arrivedAt         DateTime? // entró al geofence
  deliveredAt       DateTime? // staff lo finalizó
  endedAt           DateTime?
  finalizedByUserId String?

  // última telemetría
  lastLat        Float?
  lastLng        Float?
  lastHeadingDeg Float?
  lastSpeedMps   Float?
  lastPositionAt DateTime?

  // computado por backend
  etaSeconds   Int?
  etaUpdatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school           School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  pickupPoint      PickupPoint       @relation(fields: [pickupPointId], references: [id])
  parent           User              @relation("TripParent", fields: [parentId], references: [id])
  vehicle          Vehicle?          @relation(fields: [vehicleId], references: [id])
  authorizedFamily AuthorizedFamily? @relation(fields: [authorizedFamilyId], references: [id])
  finalizedBy      User?             @relation("TripFinalizedBy", fields: [finalizedByUserId], references: [id])

  tripStudents TripStudent[]
  events       TripEvent[]

  @@index([schoolId, status])
  @@index([pickupPointId, status])
  @@index([parentId, startedAt])
  @@index([parentId, status])
  @@map("trips")
}

model TripStudent {
  id        String @id @default(cuid())
  tripId    String
  studentId String

  // Entrega por-alumno: un viaje puede traer hermanos y se entregan por separado.
  // El Trip pasa a ENTREGADO solo cuando TODOS sus TripStudent tienen deliveredAt.
  deliveredAt       DateTime?
  finalizedByUserId String? // miss/staff que entregó a ESTE alumno

  trip        Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  student     Student @relation(fields: [studentId], references: [id])
  finalizedBy User?   @relation("TripStudentFinalizedBy", fields: [finalizedByUserId], references: [id])

  @@unique([tripId, studentId])
  @@index([studentId])
  @@index([finalizedByUserId])
  @@map("trip_students")
}

model TripEvent {
  id        String        @id @default(cuid())
  tripId    String
  type      TripEventType
  timestamp DateTime      @default(now())
  metadata  Json?

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId, timestamp])
  @@map("trip_events")
}

// ============================================
// Sales & commissions
// ============================================

model Vendor {
  id            String   @id @default(cuid())
  userId        String   @unique
  commissionPct Float    @default(0.10)
  // duración de la comisión en periodos de pago mensuales (ej: 10% por 3 meses);
  // null = sin límite
  commissionMonths Int?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrolledSchools VendorSchool[]
  commissions     Commission[]   @relation("VendorCommissions")

  @@map("vendors")
}

model VendorSchool {
  id         String   @id @default(cuid())
  vendorId   String
  schoolId   String
  enrolledAt DateTime @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([vendorId, schoolId])
  @@map("vendor_schools")
}

// ============================================
// Stripe billing (per school)
// ============================================

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  PAUSED
}

model Subscription {
  id                   String             @id @default(cuid())
  schoolId             String             @unique
  stripeSubscriptionId String?            @unique
  // "stripe" (cobro recurrente en Stripe) | "openpay" (México). El ruteo lo decide School.country/currency.
  provider             String             @default("stripe")
  status               SubscriptionStatus @default(TRIALING)
  pricePerStudent      Float              @default(10) // monto/alumno/mes en `currency`
  currency             String             @default("USD") // ISO 4217; copia de School.currency al crear
  // Openpay no soporta suscripción per-seat dinámica: archivamos la tarjeta (source_id) + el
  // device_session_id capturado al registrarla, y un cron cobra activeStudents x pricePerStudent cada mes.
  openpayCardId          String?
  openpayDeviceSessionId String?
  nextChargeAt           DateTime?
  // Fin del periodo de prueba, configurable por colegio por el super_admin (Netflix-style).
  // Al guardar tarjeta, nextChargeAt = max(now, trialEndsAt): los días gratis se respetan.
  trialEndsAt          DateTime?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAt             DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ============================================
// Support
// ============================================

enum TicketType {
  BUG
  IMPROVEMENT
  SUPPORT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model SupportTicket {
  id           String       @id @default(cuid())
  reportedById String
  schoolId     String?
  type         TicketType
  title        String
  description  String
  status       TicketStatus @default(OPEN)
  createdAt    DateTime     @default(now())
  resolvedAt   DateTime?

  reportedBy User    @relation(fields: [reportedById], references: [id])
  school     School? @relation(fields: [schoolId], references: [id])

  @@index([status])
  @@index([schoolId])
  @@map("support_tickets")
}

// ============================================
// Push notifications + alerts
// ============================================

model PushToken {
  id             String   @id @default(cuid())
  userId         String
  expoPushToken  String   @unique
  platform       String   // ios | android
  createdAt      DateTime @default(now())
  lastSeenAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_tokens")
}

enum AlertType {
  TRIP_OVERDUE
  ARRIVED_NOT_DELIVERED
  INVITATION_STALE
}

enum AlertSeverity {
  info
  warning
  critical
}

model Alert {
  id           String        @id @default(cuid())
  schoolId     String
  type         AlertType
  targetUserId String?
  targetRole   String?
  payload      Json
  severity     AlertSeverity @default(info)
  readAt       DateTime?
  createdAt    DateTime      @default(now())

  school     School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  targetUser User?  @relation("AlertTargetUser", fields: [targetUserId], references: [id])

  @@index([schoolId, readAt])
  @@index([targetUserId, readAt])
  @@index([type, createdAt])
  @@map("alerts")
}

// ============================================
// Messaging (school <-> parent)
// ============================================

model Conversation {
  id        String   @id @default(cuid())
  schoolId  String
  parentId  String
  subject   String?
  lastMessageAt DateTime @default(now())
  unreadStaff   Int      @default(0)
  unreadParent  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school   School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  parent   User      @relation("ConvParent", fields: [parentId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([schoolId, parentId])
  @@index([schoolId, lastMessageAt])
  @@map("conversations")
}

enum MessageSenderType {
  PARENT
  STAFF
  SYSTEM
}

model Message {
  id             String            @id @default(cuid())
  conversationId String
  senderId       String?
  senderType     MessageSenderType
  body           String
  readAt         DateTime?
  createdAt      DateTime          @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User?        @relation("MessageSender", fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ============================================
// Temporary authorizations (niñera, ocasionales)
// ============================================

model TemporaryAuthorization {
  id            String   @id @default(cuid())
  schoolId      String
  parentId      String
  personName    String
  // tipo de documento del país (DUI/DNI/RFC/CURP/PASSPORT/OTHER). Acompaña a documentId.
  documentType  String?
  documentId    String?
  vehicleInfo   String?
  validDate     DateTime
  code          String   @unique
  studentIds    String[]
  usedAt        DateTime?
  usedByStaffId String?
  revokedAt     DateTime?
  createdAt     DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  parent User   @relation("TempAuthParent", fields: [parentId], references: [id], onDelete: Cascade)
  usedByStaff User? @relation("TempAuthUsedBy", fields: [usedByStaffId], references: [id])

  @@index([schoolId, validDate])
  @@index([parentId])
  @@map("temporary_authorizations")
}

// ============================================
// Audit log
// ============================================

model AuditLog {
  id        String   @id @default(cuid())
  schoolId  String?
  actorId   String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id])

  @@index([schoolId, createdAt])
  @@index([actorId, createdAt])
  @@map("audit_logs")
}

// ============================================
// Import jobs (Excel)
// ============================================

enum ImportJobStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

model ImportJob {
  id          String          @id @default(cuid())
  schoolId    String
  createdById String
  filename    String
  status      ImportJobStatus @default(PENDING)
  totalRows   Int             @default(0)
  successRows Int             @default(0)
  errorRows   Int             @default(0)
  warnings    Int             @default(0)
  report      Json?
  createdAt   DateTime        @default(now())
  finishedAt  DateTime?

  school    School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdBy User   @relation("ImportJobCreator", fields: [createdById], references: [id])

  @@index([schoolId, createdAt])
  @@map("import_jobs")
}

// ============================================
// Route cache (Google Directions)
// ============================================

model RouteCache {
  id           String   @id @default(cuid())
  cacheKey     String   @unique
  originLat    Float
  originLng    Float
  destLat      Float
  destLng      Float
  durationSec  Int
  distanceMet  Int
  polyline     String
  createdAt    DateTime @default(now())
  hitCount     Int      @default(0)

  @@index([destLat, destLng])
  @@map("route_cache")
}

// ============================================
// Permission restrictions (custodia)
// ============================================

model PermissionRestriction {
  id          String   @id @default(cuid())
  schoolId    String
  studentId   String
  blockedUserId String?
  description String
  documentUrl String?
  startsAt    DateTime?
  endsAt      DateTime?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([schoolId])
  @@index([studentId])
  @@map("permission_restrictions")
}

// ============================================
// Notifications (mobile push history)
// ============================================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  sentAt    DateTime @default(now())

  user User @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@map("notifications")
}

// ============================================
// Commissions & invoices
// ============================================

enum CommissionStatus {
  PENDING
  PAID
  CANCELED
}

model Commission {
  id          String           @id @default(cuid())
  vendorId    String
  schoolId    String
  amount      Float
  status      CommissionStatus @default(PENDING)
  periodStart DateTime
  periodEnd   DateTime
  paidAt      DateTime?
  createdAt   DateTime         @default(now())

  vendor Vendor @relation("VendorCommissions", fields: [vendorId], references: [id], onDelete: Cascade)
  school School @relation("SchoolCommissions", fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([vendorId, status])
  @@index([schoolId, periodStart])
  @@map("commissions")
}

enum InvoiceStatus {
  PENDING
  PAID
  FAILED
  VOID
}

model Invoice {
  id              String        @id @default(cuid())
  schoolId        String
  stripeInvoiceId String?       @unique
  provider        String        @default("stripe")
  openpayChargeId String?       @unique
  // `${schoolId}:${YYYY-MM}` — order_id de Openpay y guard a nivel DB contra doble cobro del mismo periodo.
  idempotencyKey  String?       @unique
  amount          Float
  status          InvoiceStatus @default(PENDING)
  periodStart     DateTime?
  periodEnd       DateTime?
  pdfUrl          String?
  createdAt       DateTime      @default(now())
  paidAt          DateTime?

  school School @relation("SchoolInvoices", fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, createdAt])
  @@map("invoices")
}
