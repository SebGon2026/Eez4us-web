# =========================
# Database — Prisma Postgres + Accelerate
# =========================
# Runtime (Cloudflare Workers usa SOLO esta):
DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_ACCELERATE_API_KEY"
# CLI: migraciones, db push, studio, seeds. NUNCA en runtime de Workers.
DIRECT_URL="postgres://USER:PASSWORD@db.prisma.io:5432/postgres?sslmode=require"
# Reserva (pooling sin Accelerate). Hoy no se usa.
POOLED_URL="postgres://USER:PASSWORD@pooled.db.prisma.io:5432/postgres?sslmode=require"

# =========================
# better-auth
# =========================
# Generar: openssl rand -base64 32
BETTER_AUTH_SECRET="REPLACE_WITH_32_BYTE_BASE64"
BETTER_AUTH_URL="https://www.tu-dominio.tld"

# =========================
# Pusher Channels
# =========================
PUSHER_APP_ID="REPLACE"
PUSHER_KEY="REPLACE"
PUSHER_SECRET="REPLACE"
PUSHER_CLUSTER="mt1"
# Ortogonal al PUSHER_SECRET. Generar: openssl rand -base64 32
PUSHER_ENCRYPTION_MASTER_KEY="REPLACE_WITH_32_BYTE_BASE64"

# Exposed al cliente:
NEXT_PUBLIC_PUSHER_KEY="REPLACE"
NEXT_PUBLIC_PUSHER_CLUSTER="mt1"

# =========================
# Google Maps
# =========================
# Web: restringir por HTTP referrer (admin.tu-dominio.tld/*)
NEXT_PUBLIC_GOOGLE_MAPS_WEB_KEY="REPLACE"
# Backend (Directions/Geocoding). Restringir por API en GCP Console.
GOOGLE_MAPS_BACKEND_KEY="REPLACE"

# =========================
# Stripe (cobro recurrente B2B a escuelas)
# =========================
STRIPE_SECRET_KEY="sk_test_REPLACE"
STRIPE_WEBHOOK_SECRET="whsec_REPLACE"
# Price recurrente 10 USD/alumno/mes, billing_scheme=per_unit
STRIPE_PRICE_ID="price_REPLACE"
# URL a la que el Customer Portal redirige al cerrar sesión
STRIPE_PORTAL_RETURN_URL="https://www.tu-dominio.tld/admin/billing"

# =========================
# App
# =========================
NEXT_PUBLIC_APP_URL="https://www.tu-dominio.tld"
