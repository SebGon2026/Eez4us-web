# =========================
# Database — Prisma Postgres + Accelerate
# =========================
# Runtime (Cloudflare Workers usa SOLO esta):
DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_ACCELERATE_API_KEY"
# CLI: migraciones, db push, studio, seeds. NUNCA en runtime de Workers.
DIRECT_URL="postgres://USER:PASSWORD@db.prisma.io:5432/postgres?sslmode=require"
# Reserva (pooling sin Accelerate). Hoy no se usa.
POOLED_URL="postgres://USER:PASSWORD@pooled.db.prisma.io:5432/postgres?sslmode=require"

# =========================
# better-auth
# =========================
# Generar: openssl rand -base64 32
BETTER_AUTH_SECRET="REPLACE_WITH_32_BYTE_BASE64"
BETTER_AUTH_URL="https://www.tu-dominio.tld"

# =========================
# Pusher Channels
# =========================
PUSHER_APP_ID="REPLACE"
PUSHER_KEY="REPLACE"
PUSHER_SECRET="REPLACE"
PUSHER_CLUSTER="mt1"
# Ortogonal al PUSHER_SECRET. Generar: openssl rand -base64 32
PUSHER_ENCRYPTION_MASTER_KEY="REPLACE_WITH_32_BYTE_BASE64"

# Exposed al cliente:
NEXT_PUBLIC_PUSHER_KEY="REPLACE"
NEXT_PUBLIC_PUSHER_CLUSTER="mt1"

# =========================
# Google Maps
# =========================
# Web: restringir por HTTP referrer (admin.tu-dominio.tld/*)
NEXT_PUBLIC_GOOGLE_MAPS_WEB_KEY="REPLACE"
# Backend (Directions/Geocoding). Restringir por API en GCP Console.
GOOGLE_MAPS_BACKEND_KEY="REPLACE"

# =========================
# Stripe (cobro recurrente B2B a escuelas)
# =========================
STRIPE_SECRET_KEY="sk_test_REPLACE"
STRIPE_WEBHOOK_SECRET="whsec_REPLACE"
# Price recurrente 10 USD/alumno/mes, billing_scheme=per_unit
STRIPE_PRICE_ID="price_REPLACE"
# URL a la que el Customer Portal redirige al cerrar sesión
STRIPE_PORTAL_RETURN_URL="https://www.tu-dominio.tld/admin/billing"

# =========================
# Openpay México (cobro B2B a escuelas de México; el resto del mundo sigue en Stripe)
# Ruteo por School.currency=MXN / School.country=MX. Tarjeta archivada + cargo mensual por cron.
# =========================
# Dashboard Openpay > Configuración. Privada = sk_... (server), pública = pk_... (cliente).
OPENPAY_MERCHANT_ID="REPLACE"
OPENPAY_PRIVATE_KEY="sk_REPLACE"
# "true" => https://api.openpay.mx (producción). Cualquier otro valor => sandbox.
OPENPAY_PRODUCTION="false"
# HTTP Basic que Openpay usa para llamar NUESTRO webhook (los inventás vos; generá un pass fuerte).
OPENPAY_WEBHOOK_USER="REPLACE"
OPENPAY_WEBHOOK_PASSWORD="REPLACE_WITH_32_BYTE_BASE64"
# Precio por alumno/mes en MXN (Stripe usa STRIPE_PRICE_ID en USD por separado).
OPENPAY_MXN_PRICE_PER_STUDENT="99"
# Precio por alumno/mes en USD para escuelas fuera de México (modelo del dueño: 99 MXN / 6.99 USD).
USD_PRICE_PER_STUDENT="6.99"
# "true" bloquea el panel del director con trial vencido sin tarjeta (hoy APAGADO: solo se avisa).
BILLING_BLOCK_ON_PAST_DUE="false"
# Exposed al cliente (Openpay.js tokeniza la tarjeta en el panel del director). build-time.
NEXT_PUBLIC_OPENPAY_MERCHANT_ID="REPLACE"
NEXT_PUBLIC_OPENPAY_PUBLIC_KEY="pk_REPLACE"
# "false" => producción; cualquier otro valor => sandbox.
NEXT_PUBLIC_OPENPAY_SANDBOX="true"

# =========================
# Resend oficial (api.resend.com) — canal EMAIL
# =========================
# API key de resend.com (formato re_...); alcanza con permiso "sending access".
RESEND_API_KEY="re_REPLACE"
# API pública de Resend.
RESEND_BASE_URL="https://api.resend.com"
# Remitente con dominio verificado en el servidor. Email plano (to se manda como array).
EMAIL_FROM="tequio-mail@eez4us.com"

# =========================
# n8n (canal WHATSAPP + facturas/citas)
# =========================
N8N_WEBHOOK_URL="https://n8n.tu-dominio.tld/webhook/REPLACE"

# =========================
# Ops
# =========================
# Auth del scheduled handler (cron). Generar: openssl rand -base64 32
CRON_SECRET="REPLACE_WITH_32_BYTE_BASE64"
# Token de cuenta Expo para push (https://expo.dev/accounts/[acc]/settings/access-tokens)
EXPO_ACCESS_TOKEN="REPLACE"

# =========================
# App
# =========================
NEXT_PUBLIC_APP_URL="https://www.tu-dominio.tld"
